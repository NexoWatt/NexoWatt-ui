{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "moduleResolution": "nodenext",
    "module": "NodeNext"
  },
  "include": [
    "www/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "admin/react/assets"
  ]
}
