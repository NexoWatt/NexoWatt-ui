{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "rootDir": "src-ts",
    "outDir": "build-ts/script-mirrors",
    "removeComments": false
  },
  "include": [
    "src-ts/scripts/publish-check-rules.ts"
  ],
  "exclude": [
    "node_modules",
    "build-ts",
    "src-ts/tests/**/*",
    "src-ts/quality/**/*"
  ]
}
