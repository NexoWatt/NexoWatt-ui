{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src-ts",
    "outDir": "build-ts/energy-flow-regression",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "src-ts/types/**/*.d.ts",
    "src-ts/contracts/**/*.ts",
    "src-ts/utils/**/*.ts",
    "src-ts/quality/energy-flow-regression-cases.ts",
    "src-ts/tests/energy-flow-regression-runtime.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "build-types",
    "build-ts"
  ]
}
