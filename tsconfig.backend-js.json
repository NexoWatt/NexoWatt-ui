{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "module": "Node16",
    "moduleResolution": "node16"
  },
  "include": [
    "main.js",
    "ems/**/*.js",
    "scripts/**/*.js"
  ],
  "exclude": [
    "node_modules",
    ".nwcore"
  ]
}
