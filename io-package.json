{
  "common": {
    "name": "nexowatt-ui",
    "version": "0.8.75",
    "news": {
      "0.8.75": {
        "de": "Version 0.8.75: Entfernt den Passwortschutz aus dem Kunden-/LIVE-Frontend. Schnellsteuerung, EVCS, SmartHome, RFID und Kundeneinstellungen sind ohne Admin-/Installer-Login bedienbar; App-Center, Simulation, Mapping und Lizenz bleiben geschützt.",
        "en": "Version 0.8.75: Removes the password gate from the customer/LIVE frontend. Quick controls, EVCS, SmartHome, RFID and customer settings are operable without admin/installer login; App Center, simulation, mapping and license remain protected."
      },
      "0.8.74": {
        "de": "Version 0.8.74: History-Verbraucherfarben stärker getrennt. Speicherfarm erscheint im Kundenmenü nur, wenn die App im App-Center aktiv ist und eine echte Farm-Konfiguration vorhanden ist.",
        "en": "Version 0.8.74: History extra-consumer colors are more distinct. Storage Farm appears in the customer menu only when the app is active in the App Center and a real farm configuration exists."
      },
      "0.8.73": {
        "de": "Version 0.8.73: EVCS-Kacheln flackern beim Hover nicht mehr. Hover bleibt auf der Ladepunktseite neutral; grüne Umrandung/Leuchten erscheint nur bei echter aktiver Ladung.",
        "en": "Version 0.8.73: EVCS tiles no longer flicker on hover. Hover remains neutral on the chargepoint page; green border/glow is shown only for real active charging."
      },
      "0.8.72": {
        "de": "Version 0.8.72: App-Center-Heizstab-Eingaben stabilisiert. Stufenwerte lösen beim Tippen keinen vollständigen Rebuild mehr aus; notwendige Strukturänderungen erhalten Scrollposition und Fokus.",
        "en": "Version 0.8.72: Stabilizes App Center heating-rod inputs. Stage values no longer trigger a full rebuild while typing; required structural updates preserve scroll position and focus."
      },
      "0.8.71": {
        "de": "Version 0.8.71: Speicherregelung gegen überschießende Eigenverbrauchs-Entlade-Sollwerte gehärtet. Ist-Leistung wird nicht mehr aus Steuer-/Setpoint-DPs fürs Balancing genutzt; Demand-Cap wird nach der Rampe erneut hart angewendet.",
        "en": "Version 0.8.71: Hardens storage control against excessive self-consumption discharge setpoints. Battery actual power is no longer taken from control/setpoint datapoints for balancing; demand cap is enforced again after ramp limiting."
      },
      "0.8.70": {
        "de": "Version 0.8.70: Speicher-Einstellungen herstellerneutral bereinigt. Sichtbare FENECON-/Sungrow-Texte wurden durch allgemeine DP-Zuordnungs- und Gateway-Beschreibungen ersetzt; Legacy-IDs bleiben intern kompatibel.",
        "en": "Version 0.8.70: Cleans up storage settings to be vendor-neutral. Visible FENECON/Sungrow wording was replaced by generic datapoint-mapping and gateway descriptions; legacy IDs remain internally compatible."
      },
      "0.8.69": {
        "de": "Version 0.8.69: Speicherregelung herstelleroffener: getrennte Lade-/Entlade-Sollwert-DPs und optionaler Run-DP für Einzel-Speicher ergänzt. Eigenverbrauchs-Entladung ist für generische Speicher nun standardmäßig aktiv, solange keine Reserve-/Tarifsperre greift.",
        "en": "Version 0.8.69: Storage control is more vendor-open: adds separate charge/discharge target datapoints and an optional run datapoint for single storages. Self-consumption discharge is now enabled by default for generic storages unless reserve/tariff gates block it."
      }
    },
    "title": "NexoWatt UI",
    "titleLang": {
      "en": "NexoWatt UI",
      "de": "NexoWatt UI"
    },
    "desc": {
      "en": "responsive dashboard with NexoWatt colors (green/black). All datapoints can be linked in adapter settings.",
      "de": "responsives Dashboard in NexoWatt-Farben (grün/schwarz). Alle Datenpunkte sind in den Adaptereinstellungen verknüpfbar."
    },
    "authors": [
      "NexoWatt"
    ],
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "compact": true,
    "enabled": true,
    "loglevel": "info",
    "type": "visualization",
    "adminUI": {
