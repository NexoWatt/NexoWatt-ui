{
  "common": {
    "name": "nexowatt-ui",
    "version": "0.7.100",
    "news": {
      "0.7.95": {
        "de": "App-Center Runtime-Spiegel gezielt typisiert: Verträge für Installer-Konfiguration, DP-Mapping, Heizstab, KI, Speicherfarm, TS-Schaltmodus und Diagnose ergänzt. Keine produktive Runtime-Umstellung.",
        "en": "App-Center runtime mirror typed: added contracts for installer configuration, datapoint mapping, heating rod, AI advisor, storage farm, TS switch mode and diagnostics. No productive runtime switch."
      },
      "0.7.94": {
        "de": "TypeScript-Migration: SmartHome-Konfigurationsspiegel gezielt typisiert. Gebäude, Räume, Geräte, Funktionen, Timer, Szenen, Seiten und Auto-Erkennung sind als Verträge vorbereitet; produktive Runtime bleibt unverändert.",
        "en": "TypeScript migration: SmartHome configuration mirror received targeted typing. Buildings, rooms, devices, functions, timers, scenes, pages and auto-detection are prepared as contracts; production runtime remains unchanged."
      },
      "0.7.92": {
        "de": "History-Frontend als vierte große Runtime-Spiegeldatei gezielt typisiert: History-/Report-Verträge, Feature-Sichtbarkeit und Smoke-Test ergänzt. Keine produktive Runtime-Änderung.",
        "en": "History frontend typed as fourth large runtime mirror: added history/report contracts, feature visibility contracts and smoke test. No productive runtime change."
      },
      "0.7.91": {
        "de": "TypeScript-Migration: KI-Berater-Runtime-Spiegel gezielt typisiert. Adapter-, Snapshot-, Konfigurations-, Vorschlags-, Tagesplan- und Lernzustandsverträge ergänzt; produktive KI-Runtime bleibt JavaScript.",
        "en": "TypeScript migration: AI advisor runtime mirror received targeted typing. Added adapter, snapshot, config, suggestion, daily plan and learning state contracts; productive AI runtime remains JavaScript."
      },
      "0.7.79": {
        "de": "TypeScript-Shadow-Diagnose wird ausgewertet und zeigt eine Umschaltbereitschaft für Energiefluss, Core-Limits und Heizstab im App-Center. Keine produktive Runtime-Umschaltung.",
        "en": "TypeScript shadow diagnostics now evaluate switch-readiness for energy flow, core limits and heating rod in the App Center. No productive runtime switch."
      },
      "0.7.64": {
        "de": "Git-/TypeScript-Migrationsstabilisierung: Konfliktprüfung ergänzt, publish:check git-sicher gemacht und keine Runtime-Logik geändert.",
        "en": "Git/TypeScript migration stabilization: added conflict check, made publish:check Git-safe and did not change runtime logic."
      },
      "0.7.63": {
        "de": "TypeScript-Migrationsschritt: Backend-/API-State-Helfer für /api/state, Feature-Sichtbarkeit, info.connection und Lizenzsicherheit vorbereitet. Keine Runtime-Logik geändert.",
        "en": "TypeScript migration step: prepared backend/API-state helpers for /api/state, feature visibility, info.connection and license safety. No runtime logic changed."
      }
    },
    "title": "NexoWatt UI",
    "titleLang": {
      "en": "NexoWatt UI",
      "de": "NexoWatt UI"
    },
    "desc": {
      "en": "responsive dashboard with NexoWatt colors (green/black). All datapoints can be linked in adapter settings.",
      "de": "responsives Dashboard in NexoWatt-Farben (grün/schwarz). Alle Datenpunkte sind in den Adaptereinstellungen verknüpfbar."
    },
    "authors": [
      "NexoWatt"
    ],
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "compact": true,
    "enabled": true,
    "loglevel": "info",
    "type": "visualization",
    "adminUI": {
      "config": "json",
      "tab": "html"
    },
    "keywords": [
      "visualization",
      "ems",
      "nexowatt",
      "dashboard"
    ],
    "connectionType": "local",
    "dataSource": "poll",
    "icon": "admin.png",
    "logo": "admin_logo_.ico",
    "adminTab": {
      "name": {
        "de": "NexoWatt EMS",
        "en": "NexoWatt EMS"
      },
      "fa-icon": "bolt",
      "order": 50
    },
    "welcomeScreenPro": [
      {
        "link": "/adapter/nexowatt-ui/tab.html",
        "name": "Energiefluss",
        "desc": {
          "de": "Direkt zur NexoWatt UI (aktuelle ioBroker-IP + VIS-Port).",
          "en": "Go to NexoWatt UI (current ioBroker IP + VIS port)."
        },
        "img": "admin.png",
        "color": "#00c853",
        "order": 10,
        "localLinks": {
          "_default": "/adapter/nexowatt-ui/tab.html"
        }
      }
    ],
    "welcomeScreen": "adapter/nexowatt-ui/tab.html",
    "license": "UNLICENSED",
    "stopBeforeUpdate": true,
    "stopTimeout": 2500,
    "wwwDontUpload": true,
    "extIcon": "https://raw.githubusercontent.com/NexoWatt/NexoWatt-ui/main/admin/admin.png",
