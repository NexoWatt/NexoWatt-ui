{
  "common": {
    "name": "nexowatt-ui",
    "version": "0.8.49",
    "news": {
      "0.8.49": {
        "de": "Version 0.8.49: Access-Control berücksichtigt jetzt die vorhandenen EOS/ioBroker-Gruppen system.group.installer und system.group.user. Gespeicherte Gruppen werden mit diesen Pflichtgruppen gemerged, damit normaler Admin und EOS Admin beide funktionieren.",
        "en": "Version 0.8.49: Access control now recognizes the existing EOS/ioBroker groups system.group.installer and system.group.user. Saved group settings are merged with these mandatory groups so standard admin and EOS admin both work."
      },
      "0.8.48": {
        "de": "Version 0.8.48: EOS Access Control mit Rollen Admin, Installer und Benutzer vorbereitet. Rechte werden aus EOS/ioBroker Benutzern und Gruppen abgeleitet; Lizenzverwaltung ist Admin-only, Installer darf technische Bereiche ohne Lizenz, Benutzer darf SmartHome/NexoLogik/Kundeneinstellungen.",
        "en": "Version 0.8.48: Adds EOS access control with admin, installer and customer roles. Permissions are derived from EOS/ioBroker users and groups; license management is admin-only, installers can use technical areas except licensing, customers can use SmartHome/NexoLogic/customer settings."
      },
      "0.8.47": {
        "de": "Version 0.8.47: Mesh/Microgrid Bridge-Wiederfreigabe und Ziel-Command-Verlauf ergänzt. ACK-OK gibt Ziele automatisch wieder frei; manuelle Freigabe pro Bridge-Ziel über Betreiberansicht/API vorbereitet. Weiterhin nur neutrale Commands ohne direkte Hardwarewrites.",
        "en": "Version 0.8.47: Adds Mesh/Microgrid bridge target release and per-target command history. ACK OK automatically releases targets; manual release per bridge target is prepared via operator view/API. Still neutral commands only, no direct hardware writes."
      },
      "0.8.46": {
        "de": "Version 0.8.46: Mesh/Microgrid Bridge-ACK-Gate ergänzt. ACKs können pro lokaler Bridge-Zuordnung als Voraussetzung für Folge-Commands genutzt werden; Ziel-Ampeln und blockierte Ziele sind sichtbar. Keine direkten Hardwarewrites.",
        "en": "Version 0.8.46: Adds Mesh/Microgrid bridge ACK gate. ACKs can be required per local bridge mapping before follow-up commands; target health and blocked targets are visible. No direct hardware writes."
      },
      "0.8.44": {
        "de": "Version 0.8.44: Mesh/Microgrid Local Bridge Mapping ergänzt. Neutrale Local-First-/Grid-Last-Command-Intents können je lokalem Knoten auf eigene Ziel-Command-States geroutet werden. Die Umsetzung bleibt hersteller- und protokolloffen; keine direkten Hardwarewrites aus der Mesh-App.",
        "en": "Version 0.8.44: Adds Mesh/Microgrid Local Bridge Mapping. Neutral Local-First/Grid-Last command intents can be routed per local node to dedicated target command states. Execution remains manufacturer- and protocol-open; no direct hardware writes from the Mesh app."
      },
      "0.8.43": {
        "de": "Version 0.8.43: Mesh/Microgrid Feldtest-Verlauf und Peer-Härtung ergänzt. Peer-Fehlerklassen, Roundtrip-Ampel, Remote-Node-Matrix und Verlauf verbessern den Zwei-Instanzen-Feldtest über das getrennte Mesh-Tailscale. Keine direkten Hardwarewrites.",
        "en": "Version 0.8.43: Adds Mesh/Microgrid field-test history and peer hardening. Peer error classes, roundtrip status, remote-node matrix and history improve the two-instance field test via the separate mesh Tailscale. No direct hardware writes."
      },
      "0.8.42": {
        "de": "Version 0.8.42: Mesh/Microgrid Zwei-Instanzen-Feldtest ergänzt. Betreiber können Peer-Handshake, Status und neutralen Probe-Command über das separate Mesh-Tailscale prüfen. Keine direkten Hardwarewrites.",
        "en": "Version 0.8.42: Adds Mesh/Microgrid two-instance field test. Operators can verify peer handshake, status and neutral probe command via the separate mesh Tailscale. No direct hardware writes."
      }
    },
    "title": "NexoWatt UI",
    "titleLang": {
      "en": "NexoWatt UI",
      "de": "NexoWatt UI"
    },
    "desc": {
      "en": "responsive dashboard with NexoWatt colors (green/black). All datapoints can be linked in adapter settings.",
      "de": "responsives Dashboard in NexoWatt-Farben (grün/schwarz). Alle Datenpunkte sind in den Adaptereinstellungen verknüpfbar."
    },
    "authors": [
      "NexoWatt"
    ],
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "compact": true,
    "enabled": true,
    "loglevel": "info",
    "type": "visualization",
    "adminUI": {
