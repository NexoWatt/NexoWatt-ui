{
  "common": {
    "name": "nexowatt-ui",
    "version": "0.8.58",
    "news": {
      "0.8.58": {
        "de": "Version 0.8.58: Hotfix für Speicherfarm-App-Center. Behebt leeren Speicherfarm-Reiter durch fehlende Escape-Funktion und stellt Speicher auch aus storagesStatusJson/storagesTotal wieder her, damit vorhandene Speicher wieder sichtbar und neu anbindbar sind.",
        "en": "Version 0.8.58: Storage farm App Center hotfix. Fixes the empty storage farm tab caused by a missing escape helper and restores storages from storagesStatusJson/storagesTotal when needed, so existing storages become visible and bindable again."
      },
      "0.8.57": {
        "de": "Version 0.8.57: Behebt Speicherfarm-App-Center-Fallback. Bestehende Speicher werden im Installer wieder aus storageFarm.configJson geladen, wenn installer.configJson leer/inkonsistent ist. Keine neue Regelstrecke.",
        "en": "Version 0.8.57: Fixes storage farm App Center fallback. Existing storages are restored in the installer from storageFarm.configJson when installer.configJson is empty/inconsistent. No new control logic."
      },
      "0.8.56": {
        "de": "Version 0.8.56: Ergänzt 0-Einspeise Senken-ACK-Verlauf und Feldprotokoll. ACK-/Statuswerte je Senke werden nachgelagert überwacht, Fehler blockieren nur die betroffene Senke und der schnelle Aktivbetrieb bleibt erhalten.",
        "en": "Version 0.8.56: Adds zero-export sink ACK history and field protocol. ACK/status values per sink are monitored after commands, errors only block the affected sink and the fast active path remains intact."
      },
      "0.8.55": {
        "de": "Version 0.8.55: Ergänzt 0-Einspeise Senken-Freigabe und schnellen Aktivbetrieb. Schreibtests laufen nicht pro Regel-Tick; gespeicherte ACK-/Freigabedaten steuern Speicher, Ladepunkte, flexible Lasten, Mesh und WR-Fallback.",
        "en": "Version 0.8.55: Adds zero-export sink approval and fast active operation. Write tests are not executed every control tick; stored ACK/approval data drives storage, chargers, flexible loads, mesh and inverter fallback."
      },
      "0.8.54": {
        "de": "Version 0.8.54: Ergänzt den 0-Einspeise Inbetriebnahme-Assistenten. Die bestehende Export-Guard-Logik wird nicht doppelt gebaut; Smartmeter, WR-Write, Senkenreihenfolge, Testmodus, Write-Test-Vorschau und Feldreport werden diagnostisch geprüft.",
        "en": "Version 0.8.54: Adds the zero-export commissioning assistant. The existing Export Guard logic is not duplicated; smart meter, inverter write capability, sink priority, test mode, write-test preview and field report are checked diagnostically."
      },
      "0.8.53": {
        "de": "Version 0.8.53: Audit-/Regression-Fix. Alte Mesh-/0-Einspeise-Testskripte und Runtime-Spiegel auf den aktuellen Stand synchronisiert; keine neue Regelstrecke, keine App-Center-Detailkonfiguration im Apps-Reiter, keine Hardwarewrites aus Mesh/Microgrid.",
        "en": "Version 0.8.53: Audit/regression fix. Legacy Mesh/zero-export tests and runtime mirrors synchronized with the current version; no new control loop, no app-detail configuration in the Apps tab, no hardware writes from Mesh/Microgrid."
      },
      "0.8.52": {
        "de": "Version 0.8.52: Hotfix für 0-Einspeise Senkenkaskade. Konfigurierte Speicher-/Ladepunkt-/Flex-/Mesh-Command-States werden im Aktivmodus als neutrale JSON-Commands beschrieben; WR-Write fehlt nicht mehr fälschlich als alleiniger Blocker, wenn Senken verfügbar sind.",
        "en": "Version 0.8.52: Hotfix for zero-export sink cascade. Configured storage/charging/flexible/mesh command states are written as neutral JSON commands in active mode; missing inverter write points are no longer treated as the only blocker when sinks are available."
      }
    },
    "title": "NexoWatt UI",
    "titleLang": {
      "en": "NexoWatt UI",
      "de": "NexoWatt UI"
    },
    "desc": {
      "en": "responsive dashboard with NexoWatt colors (green/black). All datapoints can be linked in adapter settings.",
      "de": "responsives Dashboard in NexoWatt-Farben (grün/schwarz). Alle Datenpunkte sind in den Adaptereinstellungen verknüpfbar."
    },
    "authors": [
      "NexoWatt"
    ],
