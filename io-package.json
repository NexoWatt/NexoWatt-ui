{
  "common": {
    "name": "nexowatt-ui",
    "version": "0.8.64",
    "news": {
      "0.8.64": {
        "de": "Version 0.8.64: Budget-Konsistenzmonitor und EVCS-Ist/Reservierung-Korrektur. PV-Budget bleibt physikalisch durch aktuelle PV-Erzeugung geklemmt; EVCS-Ist wird nicht mehr aus Reservierung oder Setpoint angezeigt.",
        "en": "Version 0.8.64: Budget consistency monitor and EVCS actual/reservation correction. PV budget remains physically capped by current PV generation; EVCS actual is no longer displayed from reservation or setpoint values."
      },
      "0.8.63": {
        "de": "Version 0.8.63: Fix für zentrales PV-Budget. PV-Budget wird jetzt durch die tatsächliche PV-Erzeugung gedeckelt, damit EVCS-/Speicher-Reservierungen bei PV=0 kein künstliches PV-Budget erzeugen.",
        "en": "Version 0.8.63: Fixes central PV budget. PV budget is now capped by actual PV production so EVCS/storage reservations cannot create artificial PV budget when PV=0."
      },
      "0.8.62": {
        "de": "Version 0.8.62: Fix für Lastmanagement Budget/EVCS-Istwerte. Gate A nutzt nur frisch gemessene EVCS-Leistung für Netzbudget; stale Reservierungen erzeugen kein fiktives EVCS-Cap und EVCS-Ist/Reservierung werden getrennt angezeigt.",
        "en": "Version 0.8.62: Fixes load management budget/EVCS actual values. Gate A uses only fresh measured EVCS power for grid budgeting; stale reservations no longer create fictitious EVCS cap and EVCS actual/reservation are displayed separately."
      },
      "0.8.61": {
        "de": "Version 0.8.61: Behebt EVCS-Netzbudget-Anzeige und Berechnung. Negative Grundlast durch Speicher/PV-Entlastung wird nicht mehr als wirksame Grundlast genutzt; EVCS Cap (Netz) bleibt hart auf das effektive Netzlimit geklemmt. Lokale Entlastung wird separat diagnostiziert.",
        "en": "Version 0.8.61: Fixes EVCS grid budget display and calculation. Negative base load caused by storage/PV support is no longer used as effective base load; EVCS grid cap is hard-clamped to the effective grid limit. Local support is shown separately."
      },
      "0.8.60": {
        "de": "Version 0.8.60: Core-Limits TS-Shadow Log-Fix. grid.effectiveW-Abweichungen bleiben im Diagnose-JSON, werden aber als diagnosticOnly klassifiziert und erzeugen keinen minütlichen Warn-Log-Spam mehr. Keine Änderung an produktiver Regelung oder Hardwaresteuerung.",
        "en": "Version 0.8.60: Core-Limits TS-shadow log fix. grid.effectiveW deviations remain in diagnostics but are classified as diagnosticOnly and no longer create minute-by-minute warning log spam. No change to productive control or hardware writes."
      },
      "0.8.59": {
        "de": "Version 0.8.59: Release-Schutz / Regression Safety Gate ergänzt. Der App-Center Save-Payload schützt Speicherfarm, Ladepunkte, Mesh/Microgrid-Knoten und Zielgruppen vor versehentlichem Leerüberschreiben durch stale/fehlerhaft gerenderte UI.",
        "en": "Version 0.8.59: Adds release protection / regression safety gate. App Center save payload protects storage farm, charging stations, mesh/microgrid nodes and target groups from accidental empty overwrites caused by stale or broken UI rendering."
      },
      "0.8.58": {
        "de": "Version 0.8.58: Hotfix für Speicherfarm-App-Center. Behebt leeren Speicherfarm-Reiter durch fehlende Escape-Funktion und stellt Speicher auch aus storagesStatusJson/storagesTotal wieder her, damit vorhandene Speicher wieder sichtbar und neu anbindbar sind.",
        "en": "Version 0.8.58: Storage farm App Center hotfix. Fixes the empty storage farm tab caused by a missing escape helper and restores storages from storagesStatusJson/storagesTotal when needed, so existing storages become visible and bindable again."
      }
    },
    "title": "NexoWatt UI",
    "titleLang": {
      "en": "NexoWatt UI",
      "de": "NexoWatt UI"
    },
    "desc": {
      "en": "responsive dashboard with NexoWatt colors (green/black). All datapoints can be linked in adapter settings.",
      "de": "responsives Dashboard in NexoWatt-Farben (grün/schwarz). Alle Datenpunkte sind in den Adaptereinstellungen verknüpfbar."
    },
    "authors": [
      "NexoWatt"
