{
  "common": {
    "name": "nexowatt-ui",
    "version": "0.8.35",
    "news": {
      "0.8.35": {
        "de": "Version 0.8.35: Ergänzt eine EOS Mesh/Microgrid Betreiberansicht mit Cluster-Summen, Knotenliste, Local-First/Grid-Last-Diagnose sowie JSON-/CSV-Snapshotexport. Keine Hardwaresteuerung, weiterhin read-only.",
        "en": "Version 0.8.35: Adds an EOS Mesh/Microgrid operator view with cluster totals, node list, Local-First/Grid-Last diagnostics and JSON/CSV snapshot export. No hardware control, still read-only."
      },
      "0.8.34": {
        "de": "Version 0.8.34: Korrigiert den Zurück-zum-Installer-Button im App-Center. Der Rücksprung führt jetzt auf den ioBroker-/EOS-Admin-Tab #tab-nexowatt-ui-0 statt auf /tab.html am Adapter-Port.",
        "en": "Version 0.8.34: Fixes the App Center back-to-installer button. It now returns to the ioBroker/EOS admin tab #tab-nexowatt-ui-0 instead of /tab.html on the adapter port."
      },
      "0.8.33": {
        "de": "Version 0.8.33: App-Center aufgeräumt. Länderprofil und NL P1/DSMR liegen im Reiter Zuordnung, DC-Stationsseiten unter Ladepunkte. Zurück-zum-Installer-Button ergänzt und Speicherfarm als Master-Detail-Ansicht für mehrere Speicher verbessert.",
        "en": "Version 0.8.33: Cleans up the App Center. Country profile and NL P1/DSMR moved to Mapping, DC station display settings to Charging Points. Adds back-to-installer button and improves storage farm as master-detail view for multiple storages."
      },
      "0.8.32": {
        "de": "Version 0.8.32: Ergänzt EOS Mesh/Microgrid als separate App mit read-only Knoten-/Cluster-/Energy-Intent-Datenmodell. Die App ist EOS-only, hersteller- und protokolloffen und schreibt keine Hardware-Sollwerte.",
        "en": "Version 0.8.32: Adds EOS Mesh/Microgrid as a separate app with a read-only node/cluster/energy-intent data model. The app is EOS-only, manufacturer/protocol agnostic and does not write hardware setpoints."
      },
      "0.8.31": {
        "de": "Version 0.8.31: Niederlande-Basis mit P1/DSMR-Mapping, Netafname/Teruglevering-Normalisierung, Saldering-Exit-Grundlogik und Energy-Wallet-Brücke ergänzt. Export Guard bleibt nur mit Installerfreigabe aktiv.",
        "en": "Version 0.8.31: Adds Netherlands baseline with P1/DSMR mapping, Netafname/Teruglevering normalization, Saldering exit basics and Energy Wallet bridge. Export Guard still requires installer approval."
      },
      "0.8.30": {
        "de": "Version 0.8.30: Export Guard Stabilisierung mit Diagnose/Testmodus ergänzt. Installer-Diagnose zeigt aktuelle Einspeisung, erlaubtes Limit, geplante Aktion, WR-Schreibfähigkeit und Negative-Preis-Strategie. Generierte ZIP/TGZ-Artefakte bleiben vom Paket ausgeschlossen.",
        "en": "Version 0.8.30: Adds Export Guard stabilization with diagnostic/test mode. Installer diagnostics show current export, allowed limit, planned action, inverter write capability and negative-price strategy. Generated ZIP/TGZ artifacts remain excluded from the package."
      },
      "0.8.29": {
        "de": "Version 0.8.29: Export Guard Diagnose erweitert. Aktuelle Einspeisung vs. erlaubtes Limit, Abregelungsleistung, fehlende WR-Write-Datenpunkte und negative-Preis-Strategie werden sichtbar. Energie-Wertkonto bereitet abgeregelte kWh und nicht genutzten PV-Wert vor.",
        "en": "Version 0.8.29: Extends Export Guard diagnostics. Current export versus allowed limit, curtailment power, missing inverter write datapoints and negative-price strategy are visible. Energy Wallet prepares curtailed kWh and unused PV value."
      }
    },
    "title": "NexoWatt UI",
    "titleLang": {
      "en": "NexoWatt UI",
      "de": "NexoWatt UI"
    },
    "desc": {
      "en": "responsive dashboard with NexoWatt colors (green/black). All datapoints can be linked in adapter settings.",
      "de": "responsives Dashboard in NexoWatt-Farben (grün/schwarz). Alle Datenpunkte sind in den Adaptereinstellungen verknüpfbar."
    },
    "authors": [
      "NexoWatt"
    ],
    "platform": "Javascript/Node.js",
    "mode": "daemon",
    "compact": true,
    "enabled": true,
    "loglevel": "info",
    "type": "visualization",
    "adminUI": {
      "config": "json",
      "tab": "html"
    },
    "keywords": [
      "visualization",
      "ems",
      "nexowatt",
      "dashboard"
    ],
    "connectionType": "local",
    "dataSource": "poll",
    "icon": "admin.png",
