{
  "name": "iobroker.nexowatt-ui",
  "version": "0.7.56",
  "description": "Responsive NexoWatt EMS visualization adapter.",
  "author": "NexoWatt",
  "license": "UNLICENSED",
  "main": "main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node main.js",
    "dev": "node main.js",
    "bump:patch": "node scripts/bump-version.js patch",
    "bump:minor": "node scripts/bump-version.js minor",
    "bump:major": "node scripts/bump-version.js major",
    "githooks:install": "node scripts/install-githooks.js",
    "admin:install": "npm --prefix src-admin-tab install",
    "admin:build": "npm --prefix src-admin-tab run build",
    "build": "npm run admin:build",
    "publish:check": "node scripts/verify-publish.js && npm run typecheck",
    "prepublishOnly": "npm run publish:check",
    "test": "npm run test:package && npm run typecheck",
    "test:package": "node scripts/verify-publish.js && npm pack --dry-run",
    "test:js": "node scripts/verify-publish.js",
    "ioBroker:check": "node scripts/verify-publish.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:types": "npm run typecheck"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "@iobroker/type-detector": "5.0.10",
    "express": "^4.22.2"
  },
  "keywords": [
    "ioBroker",
    "adapter",
    "visualization",
    "NexoWatt",
    "Energie Management System",
    "EMS"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NexoWatt/NexoWatt-ui.git"
  },
  "bugs": {
    "url": "https://github.com/NexoWatt/NexoWatt-ui/issues"
  },
  "homepage": "https://github.com/NexoWatt/NexoWatt-ui#readme",
  "files": [
    "admin/**/*",
    "www/**/*",
    "main.js",
    "io-package.json",
    "README.md",
    "LICENSE",
    "ems/**/*",
    "docs/**/*",
    "src-ts/**/*",
    "tsconfig.json"
  ],
  "devDependencies": {
    "@iobroker/testing": "^5.2.2",
    "@iobroker/adapter-dev": "^1.5.0",
    "typescript": "^5.8.3",
    "@types/node": "^22.15.32"
  }
}
