{
  "name": "iobroker.nexowatt-ui",
  "version": "0.7.61",
  "description": "Responsive NexoWatt EMS visualization adapter.",
  "author": "NexoWatt",
  "license": "UNLICENSED",
  "main": "main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node main.js",
    "dev": "node main.js",
    "bump:patch": "node scripts/bump-version.js patch",
    "bump:minor": "node scripts/bump-version.js minor",
    "bump:major": "node scripts/bump-version.js major",
    "githooks:install": "node scripts/install-githooks.js",
    "admin:install": "npm --prefix src-admin-tab install",
    "admin:build": "npm --prefix src-admin-tab run build",
    "build": "npm run admin:build",
    "publish:check": "node scripts/verify-publish.js && npm run test:energy-flow-regressions",
    "prepublishOnly": "npm run publish:check",
    "test": "npm run test:all",
    "test:package": "node scripts/verify-publish.js && npm pack --dry-run",
    "test:js": "node scripts/verify-publish.js",
    "ioBroker:check": "node scripts/verify-publish.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:types": "npm run verify:ts-scaffold && npm run test:energy-flow-utils && npm run test:energy-flow-resolver && npm run test:energy-flow-regression && npm run test:energy-flow-regression-runtime && npm run typecheck && npm run test:contracts",
    "test:all": "npm run publish:check && npm run test:types",
    "release:check": "npm run test:all && npm run build:types && npm pack --dry-run",
    "ci:check": "npm run test:all && npm run build:types && npm pack --dry-run",
    "typecheck:contracts": "tsc -p tsconfig.contracts.json --noEmit",
    "build:ts": "npm run clean:ts && npm run build:types",
    "clean:ts": "node scripts/clean-ts-build.js",
    "test:ts-scaffold": "node scripts/verify-ts-scaffold.js",
    "ts:doctor": "node scripts/ts-doctor.js",
    "test:contracts": "node scripts/verify-ts-contracts.js",
    "build:all": "npm run build && npm run build:ts",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck:backend": "tsc -p tsconfig.backend.json --noEmit",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json --noEmit",
    "verify:ts-scaffold": "node scripts/verify-ts-scaffold.js",
    "typecheck:frontend-js": "tsc -p tsconfig.frontend-js.json --noEmit",
    "typecheck:backend-js": "tsc -p tsconfig.backend-js.json --noEmit",
    "test:energy-flow-types": "npm run typecheck",
    "test:energy-flow-utils": "node scripts/verify-ts-energy-flow-utils.js",
    "test:energy-flow-resolver": "node scripts/verify-ts-energy-flow-resolver.js",
    "test:energy-flow-regressions": "node scripts/verify-energy-flow-regression-cases.js",
    "build:ts-runtime-tests": "tsc -p tsconfig.test-runtime.json",
    "test:energy-flow-regression": "node scripts/verify-ts-energy-flow-regression.js",
    "test:energy-flow-regression-runtime": "npm run clean:ts && tsc -p tsconfig.energy-flow-regression.json && node build-ts/energy-flow-regression/tests/energy-flow-regression-runtime.js"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "@iobroker/type-detector": "5.0.10",
    "express": "^4.22.2"
  },
  "keywords": [
    "ioBroker",
    "adapter",
    "visualization",
    "NexoWatt",
    "Energie Management System",
    "EMS"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NexoWatt/NexoWatt-ui.git"
  },
  "bugs": {
    "url": "https://github.com/NexoWatt/NexoWatt-ui/issues"
  },
  "homepage": "https://github.com/NexoWatt/NexoWatt-ui#readme",
  "files": [
    "admin/**/*",
    "www/**/*",
    "main.js",
    "io-package.json",
    "README.md",
    "LICENSE",
    "ems/**/*",
    "docs/**/*",
    "src-ts/**/*",
    "tsconfig.json",
    "tsconfig.base.json",
    "tsconfig.build.json",
    "tsconfig.contracts.json",
    "tests/**/*",
    "tsconfig.types.json",
    "tsconfig.backend.json",
    "tsconfig.frontend.json",
    "tsconfig*.json",
    "tests/fixtures/**/*",
    "scripts/**/*",
    "tsconfig.backend-js.json",
    "tsconfig.frontend-js.json",
    "tsconfig.test-runtime.json"
  ],
  "devDependencies": {
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^22.19.21",
    "typescript": "^5.8.3"
  }
}
