{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src-ts",
    "outDir": "build-ts/feature-visibility-shadow",
    "declaration": false,
    "sourceMap": false,
    "module": "NodeNext",
    "moduleResolution": "nodenext"
  },
  "include": [
    "src-ts/types/**/*.d.ts",
    "src-ts/contracts/**/*.ts",
    "src-ts/frontend/feature-visibility-diagnostics.ts",
    "src-ts/frontend/feature-visibility-shadow-compare.ts",
    "src-ts/quality/feature-visibility-shadow-cases.ts",
    "src-ts/tests/feature-visibility-shadow-runtime.ts"
  ],
  "exclude": [
    "node_modules",
    "build-ts"
  ]
}
