{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src-ts",
    "outDir": "build-ts/adapter-state-api",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "module": "NodeNext",
    "moduleResolution": "nodenext"
  },
  "include": [
    "src-ts/types/**/*.d.ts",
    "src-ts/contracts/**/*.ts",
    "src-ts/adapter/**/*.ts",
    "src-ts/quality/adapter-state-api-cases.ts",
    "src-ts/tests/adapter-state-api-runtime.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "build-types",
    "build-ts"
  ]
}
