{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src-ts",
    "outDir": "build-ts/test-runtime",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": false,
    "module": "Node16",
    "moduleResolution": "node16"
  },
  "include": [
    "src-ts/contracts/**/*.ts",
    "src-ts/utils/**/*.ts",
    "src-ts/quality/**/*.ts",
    "src-ts/tests/energy-flow-regression-runtime.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "build-ts"
  ]
}
