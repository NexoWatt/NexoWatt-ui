{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src-ts",
    "outDir": "build-ts/ems-budget-heating-rod",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "src-ts/types/**/*.d.ts",
    "src-ts/contracts/**/*.ts",
    "src-ts/utils/**/*.ts",
    "src-ts/ems/**/*.ts",
    "src-ts/quality/ems-budget-heating-rod-cases.ts",
    "src-ts/tests/ems-budget-heating-rod-runtime.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "build-types",
    "build-ts"
  ]
}
